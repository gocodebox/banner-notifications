{
  "name": "gocodebox/banner-notifications",
  "description": "Library for showing admin-area banner notices.",
  "type": "library",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "lifterlms/lifterlms-cs": "dev-trunk"
  },
  "minimum-stability": "dev",
  "archive": {
    "exclude": [
      ".*",
      "*.json",
      "*.lock",
      "*.xml",
      "*.xml.dist",
      "*.yml",
      "*.config.js",

      "README.md",

      "/src",

      "dist",
      "node_modules",
      "tests",
      "tmp",
      "vendor",

      "!/composer.json",
      "!/i18n/*.json"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
