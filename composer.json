{
  "name": "gocodebox/banner-notifications",
  "description": "Library for showing admin-area banner notices.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "lifterlms/lifterlms-cs": "dev-trunk",
    "lifterlms/lifterlms-tests": "^4.3"
  },
  "minimum-stability": "dev",
  "archive": {
    "exclude": [
      ".*",
      "*.json",
      "*.lock",
      "*.xml",
      "*.xml.dist",
      "*.yml",
      "*.config.js",

      "README.md",

      "dist",
      "node_modules",
      "tests",
      "tmp",
      "vendor",

      "!/composer.json",
      "!/i18n/*.json"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "config-cs": [
      "\"vendor/bin/phpcs\" --config-set default_standard 'LifterLMS Core'"
    ],
    "post-install-cmd": "@config-cs",
    "post-update-cmd": "@config-cs",
    "post-update-install-cmd": [
      "@config-cs"
    ],
    "tests-remove": "\"vendor/bin/llms-tests\" teardown ${TESTS_DB_NAME:-llms_av_tests} ${TESTS_DB_USER:-root} \"${TESTS_DB_PASS-password}\" ${TESTS_DB_HOST:-127.0.0.1}",
    "tests-install": [
      "\"vendor/bin/llms-tests\" install ${TESTS_DB_NAME:-llms_av_tests} ${TESTS_DB_USER:-root} \"${TESTS_DB_PASS-password}\" ${TESTS_DB_HOST:-127.0.0.1} ${WP_VERSION:-latest} false \"${WP_TESTS_VERSION-false}\"",
      "@tests-install-plugins"
    ],
    "tests-install-plugins": "\"vendor/bin/llms-tests\" plugin lifterlms",
    "tests-reinstall": [
      "@tests-remove",
      "@tests-install"
    ],
    "tests": "\"vendor/bin/phpunit\"",
    "tests-run": "\"vendor/bin/phpunit\""
  }
}
